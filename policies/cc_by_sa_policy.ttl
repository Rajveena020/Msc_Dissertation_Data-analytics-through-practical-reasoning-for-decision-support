@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix dc:   <http://purl.org/dc/terms/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/policy/> .

# =====================================================================================================================================================
# Cross-reference: rdflicense CC-BY-SA encoding at http://purl.org/NET/rdflicense/cc-by-sa4.0 rdflicense uses cc:ShareAlike as a duty action.
# This encoding uses the standard ODRL 2.2 action odrl:shareAlike, and preserves the semantics of rdflicense whilst conforming to the ODRL 2.2 
# core vocabulary.
# ==================================================================================================================================================

ex:CC_BY_SA_Policy a odrl:Policy ;
    dc:title "Creative Commons Attribution-ShareAlike 4.0" ;
    dc:description "CC-BY-SA - permits use with attribution and share-alike requirement" ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:reproduce ;
        odrl:action odrl:distribute ;
        odrl:action odrl:modify ;
        odrl:action odrl:derive ;
        odrl:action odrl:commercialize ;
        odrl:duty [
            a odrl:Duty ;
            odrl:action odrl:attribute ;
            dc:description "Must attribute the original creator"
        ] ;
        odrl:duty [
            a odrl:Duty ;
            odrl:action odrl:shareAlike ;
            dc:description "Derived works must be distributed under the same CC-BY-SA licence"
        ]
    ] .