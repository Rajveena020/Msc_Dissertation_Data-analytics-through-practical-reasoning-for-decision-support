@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> . 
@prefix ex: <http://example.org/policy/> .

# =======================================================================================
# Cross-reference: rdflicense ODbL encoding at:http://purl.org/NET/rdflicense/ODbL1.0
# rdflicense dataset confirmed to include Open Data Commons licences including ODbL
# This encoding aligns with rdflicense structure but uses ODRL 2.2 vocabulary throughout
# =======================================================================================

ex:ODbL_Policy a odrl:Policy ;
    dc:title "Open Data Commons Open Database Licence v1.0" ;
    dc:description "ODbL - permits use of database with share-alike and open access requirements" ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:reproduce ;
        odrl:action odrl:distribute ;
        odrl:action odrl:modify ;
        odrl:action odrl:commercialize ;
        odrl:constraint [
            a odrl:Constraint ;
            odrl:leftOperand odrl:relicensing ;
            odrl:operator odrl:isA ;
            odrl:rightOperand odrl:shareAlike ;
            dc:description "Any derived database must be published under ODbL"
        ] ;
        odrl:duty [
            a odrl:Duty ;
            odrl:action odrl:attribute ;
            dc:description "Must attribute OpenStreetMap contributors"
        ]
    ] ;
    odrl:prohibition [
        a odrl:Prohibition ;
        odrl:action odrl:distribute ;
        odrl:constraint [
            a odrl:Constraint ;
            odrl:leftOperand odrl:relicensing ;
            odrl:operator odrl:isNotA ;
            odrl:rightOperand odrl:shareAlike ;
            dc:description "Cannot distribute derived database under a closed or restrictive licence"
        ]
    ] ;
    odrl:prohibition [
        a odrl:Prohibition ;
        odrl:action odrl:distribute ;
        odrl:constraint [
            a odrl:Constraint ;
            odrl:leftOperand odrl:accessibility ;
            odrl:operator odrl:isA ;
            odrl:rightOperand odrl:closed ;
            dc:description "Derived database must remain publicly accessible"
        ]
    ] .